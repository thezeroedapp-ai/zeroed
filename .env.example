# Zeroed — server environment variables
# Copy this file to .env and fill in your values
# AirDrop the .env from another dev machine — values are identical across machines

# Firebase (server-side Admin SDK)
# Firebase console → Project settings → Service accounts → Generate new private key
# Paste the full JSON on ONE line (no newlines inside)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"zeroed-3331d",...}

# Plaid — dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Anthropic — console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-...

PORT=3000
